# # Azure AI Search
# SEARCH_ENDPOINT=https://XXX.search.windows.net
# SEARCH_ADMIN_KEY=FOR_REST_CALLS

# # Entra ID tenant that owns the Search / Foundry / AOAI resources.
# # Pin this so DefaultAzureCredential issues tokens for the RIGHT tenant (avoids 403s
# # when signed into multiple tenants). Get it: az account show --query tenantId -o tsv
# AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000

# # Microsoft Fabric / OneLake
# # From https://app.fabric.microsoft.com/groups/<WORKSPACE_GUID>/lakehouses/<LAKEHOUSE_GUID>
# FABRIC_WORKSPACE_GUID=781d5032-6cf4-4d3b-8736-dde46638f5d0
# LAKEHOUSE_GUID=55bf6d8f-f60f-42f2-b55b-45b61abb4e39

# # Azure AI Foundry resource (billing target for Content Understanding skill).
# # Provision this in https://ai.azure.com.
# # ARM type: Microsoft.CognitiveServices/accounts, kind: AIServices.
# # Region MUST support Content Understanding for the modality you use:
# #   https://learn.microsoft.com/azure/ai-services/content-understanding/language-region-support
# # Document modality (mid-2026): westus, westus3, eastus, eastus2, southcentralus,
# #                               northeurope, westeurope, swedencentral, uksouth,
# #                               australiaeast, japaneast, southeastasia
# FOUNDRY_ENDPOINT=https://resourece.services.ai.azure.com/api/projects/proj-default-sweeden-central
# FOUNDRY_KEY=         # leave blank if using managed identity binding
# FOUNDRY_RESOURCE_ID=/subscriptions/7ee2b43a-eaea-4259-be7b-c8c220bfbcf9/resourceGroups/mmx-sweden-central-rg/providers/Microsoft.CognitiveServices/accounts/mmx-sweden-central-foundry

# # Azure OpenAI for embeddings
# AOAI_ENDPOINT=https://resource.openai.azure.com/openai/v1
# AOAI_EMBED_DEPL=text-embedding-3-small
# AOAI_EMBED_MODEL=text-embedding-3-small
# EMBED_DIMS=1536
