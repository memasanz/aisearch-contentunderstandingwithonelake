# Azure AI Search
SEARCH_ENDPOINT=https://<your-search>.search.windows.net
SEARCH_ADMIN_KEY=<admin-key>

# Microsoft Fabric / OneLake
# From https://app.fabric.microsoft.com/groups/<WORKSPACE_GUID>/lakehouses/<LAKEHOUSE_GUID>
FABRIC_WORKSPACE_GUID=00000000-0000-0000-0000-000000000000
LAKEHOUSE_GUID=11111111-1111-1111-1111-111111111111

# Azure AI Foundry resource (billing target for Content Understanding skill).
# Provision this in https://ai.azure.com.
# ARM type: Microsoft.CognitiveServices/accounts, kind: AIServices.
# Region MUST support Content Understanding for the modality you use:
#   https://learn.microsoft.com/azure/ai-services/content-understanding/language-region-support
# Document modality (mid-2026): westus, westus3, eastus, eastus2, southcentralus,
#                               northeurope, westeurope, swedencentral, uksouth,
#                               australiaeast, japaneast, southeastasia
FOUNDRY_ENDPOINT=https://<your-foundry>.cognitiveservices.azure.com
FOUNDRY_KEY=<key>            # leave blank if using managed identity binding
FOUNDRY_RESOURCE_ID=/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<name>

# Azure OpenAI for embeddings.
# AOAI_ENDPOINT may be either the raw AOAI endpoint or an APIM gateway URL.
#   raw : https://<aoai-name>.openai.azure.com
#   apim: https://<apim>.azure-api.net/<api-suffix>     e.g. https://mmz-apim-std.azure-api.net/mmz-ai-foundry-eastus2
# When using APIM, AOAI_KEY must be a value APIM accepts (typically the APIM subscription key).
# The APIM policy must route /openai/deployments/{deployment}/embeddings to the upstream AOAI.
AOAI_ENDPOINT=https://mmz-apim-std.azure-api.net/mmz-ai-foundry-eastus2
AOAI_KEY=<apim-subscription-key-or-aoai-key>
AOAI_EMBED_DEPL=text-embedding-3-small
AOAI_EMBED_MODEL=text-embedding-3-small
# Image verbalization (GA chain) — only needed by `..._genai_verbalization.ipynb`.
# Multimodal chat deployment must support image input (gpt-4o, gpt-4.1, gpt-4o-mini, ...).
# Re-uses AOAI_ENDPOINT + AOAI_KEY above — chat and embedding deployments live in the same resource.
AOAI_CHAT_DEPL=gpt-4o-mini
